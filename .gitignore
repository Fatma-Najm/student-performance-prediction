# ============================================================
# .gitignore — Student Performance Prediction
# ============================================================
# Files and folders listed here will NOT be tracked by Git.
# This keeps your repository clean and prevents accidentally
# uploading sensitive files, large data, or system junk.
# ============================================================


# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/


# ── Virtual Environments ───────────────────────────────────
# Do NOT commit your virtual environment to GitHub
venv/
env/
.env/
.venv/
ENV/


# ── Jupyter Notebooks ──────────────────────────────────────
# Ignore checkpoint files generated by Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# ── Environment Variables ──────────────────────────────────
# Never commit API keys or secrets
.env
.env.local
.env.*.local


# ── Data Files ─────────────────────────────────────────────
# Raw data files can be large — document download steps in README instead
# Uncomment lines below if your dataset is large (>50MB)
# data/raw/*.csv
# data/processed/*.csv


# ── Saved Models ───────────────────────────────────────────
# Trained model files can be large — consider using Git LFS or
# sharing via a release if models exceed 100MB
# models/*.pkl
# models/*.joblib


# ── OS-Generated Files ─────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── IDEs & Editors ─────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws

# Spyder
.spyderproject.cfg
.spyproject/

# Sublime Text
*.sublime-project
*.sublime-workspace


# ── Logs & Temporary Files ─────────────────────────────────
*.log
*.tmp
*.temp
logs/
tmp/


# ── Coverage & Testing ─────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/


# ── Distribution & Packaging ───────────────────────────────
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt